---
import { render, type CollectionEntry, getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Tag from "@/components/Tag.astro";
import Datetime from "@/components/Datetime.astro";
import EditPost from "@/components/EditPost.astro";
import ShareLinks from "@/components/ShareLinks.astro";
import BackButton from "@/components/BackButton.astro";
import BackToTopButton from "@/components/BackToTopButton.astro";
import { getPath } from "@/utils/getPath";
import { slugifyStr } from "@/utils/slugify";
import { getLangFromId } from "@/utils/getLangFromId";
import IconChevronLeft from "@/assets/icons/IconChevronLeft.svg";
import IconChevronRight from "@/assets/icons/IconChevronRight.svg";
import { SITE } from "@/config";
import { t, getOtherLocale, getTagDisplayName, type Locale } from "@/i18n";
import { CATEGORIES } from "@/constants";
import { buildBreadcrumbSchema } from "@/utils/schema";

type Props = {
  post: CollectionEntry<"blog">;
  posts: CollectionEntry<"blog">[];
  lang?: Locale;
};

const { post, posts, lang: langProp } = Astro.props;
const lang = langProp || getLangFromId(post.id);
const ui = t(lang);

const {
  title,
  author,
  description,
  ogImage: initOgImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  timezone,
  tags,
  hideEditPost,
  category,
} = post.data;

const { Content } = await render(post);

// Determine OG image source
let ogImageUrl: string | undefined;
if (typeof initOgImage === "string") {
  ogImageUrl = initOgImage;
} else if (initOgImage?.src) {
  ogImageUrl = initOgImage.src;
}

// Use dynamic OG image if enabled and no explicit ogImage
if (!ogImageUrl && SITE.dynamicOgImage) {
  const postPath = getPath(post.id, post.filePath, true, category).replace(/\/+$/, "");
  ogImageUrl = `${postPath}/index.png`;
}

// Resolve OG image URL
const ogImage = ogImageUrl
  ? new URL(ogImageUrl, Astro.url.origin).href
  : undefined;

// Check if translation exists for language switcher
const otherLang = getOtherLocale(lang);
const allDraftless = await getCollection("blog", ({ data }) => !data.draft);
const postSlug = post.id.split("/").slice(2).join("/");
const otherLangPost = allDraftless.find(p => {
  const pSlug = p.id.split("/").slice(2).join("/");
  return pSlug === postSlug && p.id.startsWith(`${otherLang}/`);
});
const translationExists = !!otherLangPost;
const langTargetUrl = otherLangPost
  ? getPath(otherLangPost.id, otherLangPost.filePath, true, otherLangPost.data.category)
  : undefined;

// Build alternate languages for hreflang
const alternateLanguages = (() => {
  const postUrl = getPath(post.id, post.filePath, true, category);
  const altLangs: { lang: string; href: string }[] = [];
  if (lang === "zh-CN") {
    altLangs.push({ lang: "zh-CN", href: canonicalURL || `https://iamlyx.com${postUrl}` });
    if (translationExists && langTargetUrl) {
      altLangs.push({ lang: "en", href: `https://iamlyx.com${langTargetUrl}` });
    }
  } else {
    if (translationExists && langTargetUrl) {
      altLangs.push({ lang: "zh-CN", href: `https://iamlyx.com${langTargetUrl}` });
    }
    altLangs.push({ lang: "en", href: canonicalURL || `https://iamlyx.com${postUrl}` });
  }
  return altLangs.length >= 2 ? altLangs : undefined;
})();

// Build breadcrumb data
const baseUrl = SITE.website.replace(/\/$/, "");
const langPrefix = lang === "zh-CN" ? "" : `/${lang}`;
const breadcrumbData = buildBreadcrumbSchema([
  { name: lang === "zh-CN" ? "首页" : "Home", href: `${baseUrl}${langPrefix}/` },
  ...(category ? [{ name: CATEGORIES[category]?.[lang] || category, href: `${baseUrl}${langPrefix}/${category}/` }] : []),
  { name: title, href: canonicalURL || `${baseUrl}${getPath(post.id, post.filePath, true, category)}` },
]);

const layoutProps = {
  title: `${title} | ${SITE.title}`,
  author,
  description,
  ogImage,
  canonicalURL,
  pubDatetime,
  modDatetime,
  lang,
  schemaType: "BlogPosting" as const,
  schemaData: {
    headline: title,
    image: ogImage,
    datePublished: pubDatetime,
    dateModified: modDatetime,
    description: description,
  },
  alternateLanguages,
};

/* ========== Prev/Next Posts ========== */

const allPosts = posts.map(({ data: { title, category }, id, filePath }) => ({
  id,
  title,
  filePath,
  category,
}));

const currentPostIndex = allPosts.findIndex(a => a.id === post.id);

const prevPost = currentPostIndex !== 0 ? allPosts[currentPostIndex - 1] : null;
const nextPost =
  currentPostIndex !== allPosts.length ? allPosts[currentPostIndex + 1] : null;
---

<Layout {...layoutProps}>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(breadcrumbData)} />
  <Header {lang} {langTargetUrl} {translationExists} />
  <BackButton />
  <main
    id="main-content"
    class:list={["app-layout pb-12", { "mt-8": !SITE.showBackButton }]}
    data-pagefind-body
  >
    <h1
      transition:name={slugifyStr(title.replaceAll(".", "-"))}
      class="inline-block text-2xl font-bold text-foreground sm:text-3xl"
    >
      {title}
    </h1>
    <div class="my-2 flex items-center gap-2">
      <Datetime {pubDatetime} {modDatetime} {timezone} size="lg" />
      <span
        aria-hidden="true"
        class:list={[
          "max-sm:hidden",
          { hidden: !SITE.editPost.enabled || hideEditPost },
        ]}>|</span
      >
      <EditPost {hideEditPost} {post} class="max-sm:hidden" />
    </div>
    <article
      id="article"
      class="app-prose mt-8 w-full max-w-app tracking-wider prose-pre:bg-(--shiki-light-bg) dark:prose-pre:bg-(--shiki-dark-bg)"
    >
      <Content />
    </article>

    <hr class="hr-line-b my-8 pb-px" />

    <EditPost class="sm:hidden" {hideEditPost} {post} />

    <ul class="mt-4 mb-8 flex flex-wrap gap-4 sm:my-8">
      {tags.map(tag => <Tag tag={slugifyStr(tag)} tagName={getTagDisplayName(tag, lang)} size="sm" {lang} />)}
    </ul>

    <BackToTopButton />

    <ShareLinks />

    <hr class="hr-line-b my-6 pb-px" />

    <!-- Previous/Next Post Buttons -->
    <div data-pagefind-ignore class="grid grid-cols-1 gap-6 sm:grid-cols-2">
      {
        prevPost && (
          <a
            href={getPath(prevPost.id, prevPost.filePath, true, prevPost.category)}
            class="flex w-full gap-1 hover:opacity-75"
          >
            <IconChevronLeft class="inline-block flex-none rtl:rotate-180" />
            <div>
              <span>{ui.post.prev}</span>
              <div class="text-sm text-accent/85">{prevPost.title}</div>
            </div>
          </a>
        )
      }
      {
        nextPost && (
          <a
            href={getPath(nextPost.id, nextPost.filePath, true, nextPost.category)}
            class="flex w-full justify-end gap-1 text-end hover:opacity-75 sm:col-start-2"
          >
            <div>
              <span>{ui.post.next}</span>
              <div class="text-sm text-accent/85">{nextPost.title}</div>
            </div>
            <IconChevronRight class="inline-block flex-none rtl:rotate-180" />
          </a>
        )
      }
    </div>
  </main>
  <Footer {lang} />
</Layout>

<script is:inline data-astro-rerun>
  /** Create a progress indicator at the top */
  function createProgressBar() {
    const progressContainer = document.createElement("div");
    progressContainer.className =
      "progress-container fixed top-0 z-10 h-1 w-full bg-background";

    const progressBar = document.createElement("div");
    progressBar.className = "progress-bar h-1 w-0 bg-accent";
    progressBar.id = "myBar";

    progressContainer.appendChild(progressBar);
    document.body.appendChild(progressContainer);
  }
  createProgressBar();

  /** Update the progress bar when user scrolls */
  function updateScrollProgress() {
    document.addEventListener("scroll", () => {
      const winScroll =
        document.body.scrollTop || document.documentElement.scrollTop;
      const height =
        document.documentElement.scrollHeight -
        document.documentElement.clientHeight;
      const scrolled = (winScroll / height) * 100;
      if (document) {
        const myBar = document.getElementById("myBar");
        if (myBar) {
          myBar.style.width = scrolled + "%";
        }
      }
    });
  }
  updateScrollProgress();

  /** Attaches links to headings */
  function addHeadingLinks() {
    const headings = Array.from(
      document.querySelectorAll("h2, h3, h4, h5, h6")
    );
    for (const heading of headings) {
      heading.classList.add("group");
      const link = document.createElement("a");
      link.className =
        "heading-link ms-2 no-underline opacity-75 md:opacity-0 md:group-hover:opacity-100 md:focus:opacity-100";
      link.href = "#" + heading.id;

      const span = document.createElement("span");
      span.ariaHidden = "true";
      span.innerText = "#";
      link.appendChild(span);
      heading.appendChild(link);
    }
  }
  addHeadingLinks();

  /** Attaches copy buttons to code blocks */
  function attachCopyButtons() {
    const copyButtonLabel = "Copy";
    const codeBlocks = Array.from(document.querySelectorAll("pre"));

    for (const codeBlock of codeBlocks) {
      const wrapper = document.createElement("div");
      wrapper.style.position = "relative";

      const computedStyle = getComputedStyle(codeBlock);
      const hasFileNameOffset =
        computedStyle.getPropertyValue("--file-name-offset").trim() !== "";

      const topClass = hasFileNameOffset
        ? "top-(--file-name-offset)"
        : "-top-3";

      const copyButton = document.createElement("button");
      copyButton.className = `copy-code absolute end-3 ${topClass} rounded bg-muted border border-muted px-2 py-1 text-xs leading-4 text-foreground font-medium`;
      copyButton.innerHTML = copyButtonLabel;
      codeBlock.setAttribute("tabindex", "0");
      codeBlock.appendChild(copyButton);

      codeBlock?.parentNode?.insertBefore(wrapper, codeBlock);
      wrapper.appendChild(codeBlock);

      copyButton.addEventListener("click", async () => {
        await copyCode(codeBlock, copyButton);
      });
    }

    async function copyCode(block, button) {
      const code = block.querySelector("code");
      const text = code?.innerText;

      await navigator.clipboard.writeText(text ?? "");

      button.innerText = "Copied";

      setTimeout(() => {
        button.innerText = copyButtonLabel;
      }, 700);
    }
  }
  attachCopyButtons();

  document.addEventListener("astro:after-swap", () =>
    window.scrollTo({ left: 0, top: 0, behavior: "instant" })
  );
</script>
