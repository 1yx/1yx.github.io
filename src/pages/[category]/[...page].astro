---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import postFilter from "@/utils/postFilter";
import { getLangFromId } from "@/utils/getLangFromId";
import { SITE } from "@/config";
import { CATEGORIES } from "@/constants";
import { DEFAULT_LOCALE, t, type Locale } from "@/i18n";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog", postFilter);
  const lang: Locale = DEFAULT_LOCALE;

  return Object.keys(CATEGORIES).flatMap(category => {
    const posts = allPosts.filter(
      post =>
        getLangFromId(post.id) === lang &&
        (post.data.category || "life") === category
    );
    return paginate(getSortedPosts(posts), {
      params: { category },
      pageSize: SITE.postPerPage,
    });
  });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { category } = Astro.params as { category: string };
const lang: Locale = DEFAULT_LOCALE;
const categoryName = CATEGORIES[category]?.[lang] || category;
const ui = t(lang);
---

<Layout
  title={`${categoryName} | ${SITE.title}`}
  description={ui.categoryDesc(categoryName)}
  schemaType="CollectionPage"
  schemaData={{
    name: categoryName,
    url: new URL(page.url.current, SITE.website).href,
    description: ui.categoryDesc(categoryName),
  }}
  alternateLanguages={[
    { lang: "zh-CN", href: new URL(page.url.current, SITE.website).href },
    { lang: "en", href: new URL(`/en${page.url.current}`, SITE.website).href },
  ]}
>
  <Header {lang} />
  <Main pageTitle={categoryName} pageDesc={ui.categoryDesc(categoryName)} {lang}>
    <ul>
      {page.data.map((data: any) => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} {lang} />
</Layout>
