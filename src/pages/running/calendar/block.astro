---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import BlockViewApp from "@/components/training/BlockViewApp.astro";
import { SITE } from "@/config";
import { DEFAULT_LOCALE, t, type Locale } from "@/i18n";

const lang: Locale = DEFAULT_LOCALE;
const ui = t(lang).training;
---

<Layout
  title={`${ui.blockTitle} | ${SITE.title}`}
  description={ui.blockDesc}
  alternateLanguages={[
    { lang: "zh-CN", href: `${SITE.website}running/calendar/block/` },
    { lang: "en", href: `${SITE.website}en/running/calendar/block/` },
  ]}
>
  <Header {lang} />
  <Breadcrumb {lang} />
  <main id="main-content" class="app-layout">
    <BlockViewApp {lang} />
  </main>
  <Footer {lang} />
</Layout>
