---
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import BreadcrumbAction from "@/components/BreadcrumbAction.astro";
import OverviewApp from "@/components/training/OverviewApp.astro";
import { SITE } from "@/config";
import { DEFAULT_LOCALE, getLocalePath, t, type Locale } from "@/i18n";

const lang: Locale = DEFAULT_LOCALE;
const ui = t(lang).training;
const dayPath = getLocalePath(lang, "running/calendar/day/");
---

<Layout
  title={`${ui.overviewTitle} | ${SITE.title}`}
  description={ui.overviewDesc}
  alternateLanguages={[
    { lang: "zh-CN", href: `${SITE.website}running/calendar/` },
    { lang: "en", href: `${SITE.website}en/running/calendar/` },
  ]}
>
  <Header {lang} />
  <Breadcrumb {lang} currentLabel="Calendar">
    <BreadcrumbAction href={dayPath} label="Today" />
  </Breadcrumb>
  <main id="main-content" class="app-layout">
    <OverviewApp {lang} />
  </main>
  <Footer {lang} />
</Layout>
