---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import { DEFAULT_LOCALE } from "@/i18n";
import { SITE } from "@/config";
import getPostsByLang from "@/utils/getPostsByLang";
import postFilter from "@/utils/postFilter";
import avatar from "@/assets/images/avatar.webp";

const lang = DEFAULT_LOCALE;
const allPosts = await getCollection("blog", postFilter);
const posts = getPostsByLang(allPosts, lang);

const baseUrl = SITE.website.replace(/\/$/, "");
const canonicalHref = `${baseUrl}/`;
const enHref = `${baseUrl}/en/`;

const homepageDesc = lang === "zh-CN"
  ? "Lyx (Liu Yu Xuan) 的个人博客，分享马拉松训练、心理学思考与编程实践。"
  : "Lyx (Liu Yu Xuan)'s personal blog — marathon running, psychology, and programming.";
---

<Layout
  title={`${SITE.title}`}
  description={homepageDesc}
  schemaType="WebSite"
  schemaData={{
    url: canonicalHref,
    description: homepageDesc,
    inLanguage: ["zh-CN", "en"],
  }}
  alternateLanguages={[
    { lang: "zh-CN", href: canonicalHref },
    { lang: "en", href: enHref },
  ]}
>
  <Header {lang} />
  <script is:inline>
    (function() {
      var saved = localStorage.getItem("lang");
      if (saved === null) {
        var nav = navigator.language || "";
        if (!nav.startsWith("zh")) {
          localStorage.setItem("lang", "en");
          location.replace("/en/");
        }
      } else if (saved === "en") {
        location.replace("/en/");
      }
    })();
  </script>
  <main id="main-content" class="app-layout mb-16">
    <section class="flex flex-col items-center pt-12 pb-16">
      <img
        src={avatar.src}
        alt="Lyx"
        width={avatar.width}
        height={avatar.height}
        fetchpriority="high"
        decoding="async"
        class="h-44 w-44 rounded-full object-cover sm:h-56 sm:w-56 transition-transform duration-300 ease-out hover:translate-x-[10px] hover:rotate-[5deg]"
      />
      <h1 class="mt-6 text-2xl font-semibold sm:text-3xl">{SITE.author}</h1>
      <p class="mt-3 text-center text-sm opacity-70 sm:text-base">
        马拉松跑者，程序员
      </p>
    </section>

    <section>
      <ul>
        {posts.map(data => <Card {...data} />)}
      </ul>
    </section>
  </main>
  <Footer noMarginTop={false} {lang} />
</Layout>
