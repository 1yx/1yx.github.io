---
import { getCollection, type CollectionEntry } from "astro:content";
import type { GetStaticPathsOptions, Page } from "astro";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";
import { DEFAULT_LOCALE, t, type Locale } from "@/i18n";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const posts = await getCollection("blog");
  const lang: Locale = DEFAULT_LOCALE;
  const tags = getUniqueTags(posts, lang);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag, lang);

    return paginate(tagPosts, {
      params: { tag },
      props: { tagName, lang },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params as { tag: string };
const { page, tagName, lang } = Astro.props as {
  page: Page<CollectionEntry<"blog">>;
  tagName: string;
  lang: Locale;
};
const ui = t(lang);
---

<Layout
  title={`${ui.tags.tagLabel} ${tagName} | ${SITE.title}`}
  description={ui.tags.tagDesc(tagName)}
  schemaType="CollectionPage"
  schemaData={{
    name: `${ui.tags.tagLabel} ${tagName}`,
    url: new URL(page.url.current, SITE.website).href,
    description: ui.tags.tagDesc(tagName),
  }}
  alternateLanguages={[
    { lang: "zh-CN", href: new URL(page.url.current, SITE.website).href },
    { lang: "en", href: new URL(`/en${page.url.current}`, SITE.website).href },
  ]}
>
  <Header {lang} />
  <Main
    pageTitle={[ui.tags.tagLabel, `${tagName}`]}
    titleTransition={tag}
    pageDesc={ui.tags.tagDesc(tagName)}
    {lang}
  >
    <h1 slot="title" transition:name={tag}>{`${ui.tags.tagLabel}${tag}`}</h1>
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} {lang} />
</Layout>
