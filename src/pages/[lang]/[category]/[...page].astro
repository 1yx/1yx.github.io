---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import BreadcrumbAction from "@/components/BreadcrumbAction.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import postFilter from "@/utils/postFilter";
import { getLangFromId } from "@/utils/getLangFromId";
import { SITE } from "@/config";
import { CATEGORIES } from "@/constants";
import { LOCALES, DEFAULT_LOCALE, getLocalePath, t, type Locale } from "@/i18n";

export const getStaticPaths = (async ({ paginate }) => {
  const allPosts = await getCollection("blog", postFilter);

  return LOCALES.filter(l => l !== DEFAULT_LOCALE).flatMap(lang =>
    Object.keys(CATEGORIES).flatMap(category => {
      const posts = allPosts.filter(
        post =>
          getLangFromId(post.id) === lang &&
          (post.data.category || "life") === category
      );
      return paginate(getSortedPosts(posts), {
        params: { lang, category },
        pageSize: SITE.postPerPage,
      });
    })
  );
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const { category, lang } = Astro.params as { category: string; lang: Locale };
const categoryName = CATEGORIES[category]?.[lang] || category;
const ui = t(lang);
---

<Layout
  title={`${categoryName} | ${SITE.title}`}
  description={ui.categoryDesc(categoryName)}
  schemaType="CollectionPage"
  schemaData={{
    name: categoryName,
    url: new URL(page.url.current, SITE.website).href,
    description: ui.categoryDesc(categoryName),
  }}
  alternateLanguages={[
    {
      lang: "zh-CN",
      href: new URL(page.url.current.replace(`/${lang}`, ""), SITE.website)
        .href,
    },
    { lang: "en", href: new URL(page.url.current, SITE.website).href },
  ]}
>
  <Header {lang} />
  <Main
    pageTitle={categoryName}
    pageDesc={ui.categoryDesc(categoryName)}
    {lang}
  >
    {
      category === "running" && (
        <span slot="breadcrumb-action">
          <BreadcrumbAction
            href={getLocalePath(lang, "running/calendar/")}
            label="Calendar"
          />
          <BreadcrumbAction
            href={getLocalePath(lang, "running/calendar/day/")}
            label="Today"
          />
        </span>
      )
    }
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} {lang} />
</Layout>
