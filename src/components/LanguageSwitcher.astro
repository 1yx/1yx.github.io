---
import IconLanguage from "@/assets/icons/IconLanguage.svg";
import IconLanguageOff from "@/assets/icons/IconLanguageOff.svg";
import { getOtherLocale, DEFAULT_LOCALE, type Locale } from "@/i18n";

interface Props {
  lang: Locale;
  targetUrl?: string;
  translationExists?: boolean;
}

const { lang, targetUrl, translationExists = false } = Astro.props;
const otherLang = getOtherLocale(lang);

// If targetUrl is explicitly provided, use it (e.g. blog posts with different slugs)
// Otherwise, derive from current URL by adding/removing the /en/ prefix
let href: string;
if (targetUrl) {
  href = targetUrl;
} else {
  const { pathname } = Astro.url;
  const pathWithoutTrailing = pathname.replace(/\/+$/, "");
  const segments = pathWithoutTrailing.split("/").filter(Boolean);

  if (lang === DEFAULT_LOCALE) {
    // Chinese → English: add /en/ prefix
    const path = segments.join("/");
    href = path ? `/en/${path}/` : "/en/";
  } else {
    // English → Chinese: remove /en/ prefix
    const path = segments.slice(1).join("/");
    href = path ? `/${path}/` : "/";
  }
}
---

<a
  href={href}
  onclick={`localStorage.setItem("lang","${otherLang}")`}
  class:list={[
    "focus-outline inline-flex items-center justify-center p-3 sm:p-1",
    "hover:rotate-6 hover:[&>svg]:stroke-accent-hover",
  ]}
  title={`Switch to ${otherLang === "zh-CN" ? "中文" : "English"}`}
  aria-label={`Switch language to ${otherLang === "zh-CN" ? "中文" : "English"}`}
>
  {lang === "en" ? <IconLanguage class="size-5" /> : <IconLanguageOff class="size-5" />}
</a>
