---
import { Image } from "astro:assets";

interface Props {
  src: ImageMetadata;
  alt: string;
  href?: string;
  float?: "left" | "right";
  maxWidth?: string;
  maxHeight?: string;
  clearFloat?: boolean;
  bleed?: string;
  upperLines?: number;
  collapse?: boolean;
}

const {
  src,
  alt,
  href,
  float = "left",
  maxWidth = "xs",
  maxHeight,
  clearFloat = true,
  bleed,
  upperLines = 0,
  collapse = !upperLines,
} = Astro.props;

const direction = float as "left" | "right" | undefined;
const isFloating = direction === "left" || direction === "right";
const isFloatDown = isFloating && !!upperLines;

const marginClass = isFloating
  ? direction === "left"
    ? "mr-5 mt-0 mb-0"
    : "ml-5 mt-0 mb-0"
  : "mt-0 mb-0";

const bleedStyle = bleed
  ? isFloating
    ? direction === "left"
      ? `margin-left: ${bleed};`
      : `margin-right: ${bleed};`
    : `margin-left: ${bleed}; margin-right: calc(-1 * ${bleed.replace("-", "")});`
  : "";

// Zero-width float spacer: pushes image down N text lines, invisible to text
// line-height: 28px, paragraph margin-bottom: 20px
const spacerHeight =
  isFloatDown && upperLines ? `${upperLines * 1.75 + 0.15}rem` : "";
const spacerStyle = spacerHeight
  ? `float: ${direction}; width: 0; height: ${spacerHeight};`
  : "";

const clearSide = isFloatDown ? `clear: ${direction};` : "";

// Tailwind max-width lookup — maps suffix to rem value
const tailwindMaxW: Record<string, string> = {
  none: "none",
  xs: "20rem",     // 320px
  sm: "24rem",     // 384px
  md: "28rem",     // 448px
  lg: "32rem",     // 512px
  xl: "36rem",     // 576px
  "2xl": "42rem",  // 672px
  "3xl": "48rem",  // 768px
  "4xl": "56rem",  // 896px
  "5xl": "64rem",  // 1024px
  full: "100%",
};

const resolved = tailwindMaxW[maxWidth];
const maxWStyle = `max-width: ${resolved ?? maxWidth};`;

const floatStyle = isFloating
  ? `float: ${direction}; ${maxWStyle}${maxHeight ? ` max-height: ${maxHeight};` : ""} ${bleedStyle} ${clearSide}`
  : `width: 100%; ${maxWStyle}${maxHeight ? ` max-height: ${maxHeight};` : ""} ${bleedStyle}`;
const cropStyle = maxHeight
  ? "overflow: hidden; display: flex; align-items: center;"
  : "";
---

<div style={cropStyle}>
  {spacerStyle && <div style={spacerStyle} />}
  {
    href ? (
      <a
        href={href}
        target="_blank"
        rel="noopener noreferrer"
        class:list={["block p-0 hover:rotate-1", marginClass]}
        style={floatStyle}
      >
        <Image src={src} alt={alt} class="mt-0 mb-0 block w-full" />
      </a>
    ) : (
      <Image
        src={src}
        alt={alt}
        class:list={["block", marginClass]}
        style={floatStyle}
      />
    )
  }
  {
    collapse ? (
      <div style="margin-top: -1.25rem;">
        <slot />
      </div>
    ) : (
      <slot />
    )
  }
  {isFloating && clearFloat && <div style="clear: both;" />}
</div>
