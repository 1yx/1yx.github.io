---
import IconHash from "@/assets/icons/IconHash.svg";
import { getLocalePath, type Locale } from "@/i18n";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  lang?: Locale;
};

const { tag, tagName, size = "lg", lang = "zh-CN" } = Astro.props;
---

<li>
  <a
    href={getLocalePath(lang, `tags/${tag}/`)}
    transition:name={tag}
    class:list={[
      "flex items-center gap-0.5",
      "hover:-mt-0.5 hover:text-accent-hover",
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "opacity-80",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    {tagName}
  </a>
</li>
