---
// Server-rendered overview (the /running/calendar/ landing page).
// Uses only the build-time plan (no runtime Strava data), so it renders to
// static HTML with real <a> links into the day/mesocycle views — better for SEO
// and accessibility than a client-rendered shell.
import "@/styles/training.css";
import { translations, getLocalePath, type Locale } from "@/i18n";
import {
  phases,
  allMicrocycles,
  microcycleIndex,
  phaseKm,
  dayPlannedKm,
  categoryClass,
  fmtShort,
  allDays,
  monthLabel,
  type Mesocycle,
  type Microcycle,
  type Phase,
  type PlanDay,
  type Workout,
} from "@/utils/training";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const ui = translations[lang].training;
const phaseList = phases();

const mesocyclePath = getLocalePath(lang, "running/calendar/mesocycle/");
const mesocycleHref = (pi: number, bi: number, day: number) =>
  `${mesocyclePath}?phase=${pi}&mesocycle=${bi}&day=${day}`;

const cycleTotal = (microcycle: Microcycle): string => {
  if (!microcycle.total_km) {
    return ui.plannedKm(
      (microcycle.days || []).reduce((s, d) => s + dayPlannedKm(d), 0)
    );
  }
  const parsed = parseFloat(microcycle.total_km);
  return Number.isNaN(parsed) ? microcycle.total_km : ui.plannedKm(parsed);
};

const cellText = (w: Workout | null) => (w && w.text ? w.text : ui.rest);
const phaseLabel = (name: string) =>
  (ui.phaseLabels as Record<string, string>)[name] ?? name;
const dayLabel = (n: number) =>
  lang === "zh-CN" ? `第${n}天` : `Day ${n}`;
const weekday = (iso: string) => {
  const wd = (new Date(iso + "T00:00:00Z").getUTCDay() + 6) % 7;
  return `${lang === "zh-CN" ? "周" : ""}${ui.weekdayShort[wd]}`;
};

const months = [...new Set(allDays().map(d => d.date.slice(0, 7)))].sort();

// Microcycle label, marking cutback weeks — the 4th microcycle of each mesocycle.
const mcLabel = (m: Microcycle) =>
  `${ui.microcycleLabel} ${microcycleIndex(m)}${m.taper ? ` (${ui.taper})` : m.cutback ? ` (${ui.cutback})` : ""}`;

// Microcycles of a single mesocycle, each tagged with its day offset (deep-link target).
const microcyclesOfMesocycle = (
  mesocycle: Mesocycle
): { microcycle: Microcycle; dayIndex: number }[] => {
  let dayOffset = 0;
  return (mesocycle.microcycles || mesocycle.sets || []).map(microcycle => {
    const item = { microcycle, dayIndex: dayOffset };
    dayOffset += (microcycle.days || []).length;
    return item;
  });
};
---

<div class="tx-app" data-lang={lang} data-view="microcycle" data-filter="none">
  <h1 class="text-xl font-semibold tracking-wide sm:text-2xl">
    {ui.overviewTitle}
  </h1>
  <p class="-mt-2 text-sm text-muted">{ui.overviewDesc}</p>

  {
    phaseList.length > 1 && (
      <nav class="tx-tabs" aria-label={ui.calendarNav}>
        <div class="tx-tabs__row">
          <button
            class="tx-tab tx-tab--active"
            type="button"
            data-view-toggle="microcycle"
          >
            {ui.microcycleView}
          </button>
          <a href="#" id="tx-current" class="tx-tab">
            {ui.current}
          </a>
          {phaseList.map((phase, pi) => (
            <a class="tx-tab" href={`#phase-${pi + 1}`}>
              {phaseLabel(phase.name)}
            </a>
          ))}
        </div>
        <div class="tx-tabs__row">
          <button
            class="tx-tab tx-toggle-weekly"
            type="button"
            data-view-toggle="weekly"
          >
            {ui.weeklyView}
          </button>
          <a href="#" id="tx-current-wk" class="tx-tab">
            {ui.current}
          </a>
          {months.map(ym => (
            <a href="#" class="tx-tab" data-month={ym}>
              {monthLabel(ym, lang)}
            </a>
          ))}
        </div>
        <div class="tx-tabs__row" role="group" aria-label="filters">
          <button
            class="tx-chip"
            type="button"
            aria-pressed="true"
            data-filter-toggle="none"
          >
            {ui.filterAll}
          </button>
          <button
            class="tx-chip"
            type="button"
            aria-pressed="false"
            data-filter-toggle="regeneration"
          >
            {ui.filterRegeneration}
          </button>
          <button
            class="tx-chip"
            type="button"
            aria-pressed="false"
            data-filter-toggle="fundamental"
          >
            {ui.filterFundamental}
          </button>
          <button
            class="tx-chip"
            type="button"
            aria-pressed="false"
            data-filter-toggle="special"
          >
            {ui.filterSpecial}
          </button>
          <button
            class="tx-chip"
            type="button"
            aria-pressed="false"
            data-filter-toggle="specific"
          >
            {ui.filterSpecific}
          </button>
          <button
            class="tx-chip"
            type="button"
            aria-pressed="false"
            data-filter-toggle="race"
          >
            {ui.filterRace}
          </button>
        </div>
      </nav>
    )
  }

  <div class="tx-mc-view">
    {
      phaseList.map((phase: Phase, pi: number) => {
        const items = allMicrocycles(phase);
        const days = items.reduce(
          (sum, it) => sum + it.microcycle.days.length,
          0
        );
        return (
          <section id={`phase-${pi + 1}`} class="tx-phase">
            <div class="tx-phase__head">
              <div>
                <div class="tx-phase__title">{phaseLabel(phase.name)}</div>
                <div class="tx-phase__meta">
                  {items.length} {ui.microcycles} · {days} {ui.days}
                </div>
              </div>
              <div class="tx-phase__total">
                {ui.plannedVolume}
                <strong>{phaseKm(phase)}km</strong>
              </div>
            </div>

            {/* desktop tables */}
            <div class="tx-tablewrap">
              {phase.mesocycles.map((mesocycle, bi) => {
                const ents = microcyclesOfMesocycle(mesocycle);
                const firstDays = ents[0]?.microcycle.days ?? [];
                const lastDays = ents[ents.length - 1]?.microcycle.days ?? [];
                return (
                  <div
                    class="tx-table"
                    data-first={firstDays[0]?.date}
                    data-last={lastDays[lastDays.length - 1]?.date}
                    data-href={mesocycleHref(pi, bi, 0)}
                  >
                    <table>
                      <colgroup>
                        <col class="col-label" />
                        <col class="col-day1" />
                        <col />
                        <col class="col-day3" />
                        <col />
                      </colgroup>
                      <tbody>
                        {microcyclesOfMesocycle(mesocycle).map(({ microcycle }) => {
                          const cls = microcycle.taper
                            ? " tx-cyclehead--taper"
                            : microcycle.cutback
                              ? " tx-cyclehead--cutback"
                              : "";
                          return (
                            <>
                              <tr class={`tx-cyclehead${cls}`}>
                                <th>
                                  {mcLabel(microcycle)}
                                </th>
                                {(microcycle.days || []).map((day: PlanDay) => (
                                  <td class="tx-date">
                                    {fmtShort(day.date)}{" "}
                                    <span class="tx-date__wd">{weekday(day.date)}</span>
                                  </td>
                                ))}
                              </tr>
                              <tr class="tx-row--period">
                                <th class="tx-period-label">{ui.am}</th>
                                {(microcycle.days || []).map((day: PlanDay) => (
                                  <td
                                    class={`tx-cell tx-cell--${categoryClass(day.am)}`}
                                  >
                                    {cellText(day.am)}
                                  </td>
                                ))}
                              </tr>
                              <tr class="tx-row--period">
                                <th class="tx-period-label">{ui.pm}</th>
                                {(microcycle.days || []).map((day: PlanDay) => (
                                  <td
                                    class={`tx-cell tx-cell--${categoryClass(day.pm)}`}
                                  >
                                    {cellText(day.pm)}
                                  </td>
                                ))}
                              </tr>
                            </>
                          );
                        })}
                      </tbody>
                    </table>
                  </div>
                );
              })}
            </div>

            {/* mobile cards */}
            <div class="tx-mobile">
              {phase.mesocycles.map((mesocycle, bi) => {
                const ments = microcyclesOfMesocycle(mesocycle);
                const firstDays = ments[0]?.microcycle.days ?? [];
                const lastDays = ments[ments.length - 1]?.microcycle.days ?? [];
                const first = firstDays[0]?.date;
                const last = lastDays[lastDays.length - 1]?.date;
                return ments.map(({ microcycle, dayIndex }) => {
                  const cls = microcycle.taper
                    ? " tx-cyclehead--taper"
                    : microcycle.cutback
                      ? " tx-cyclehead--cutback"
                      : "";
                  return (
                    <a
                      class="tx-cyclecard"
                      href={mesocycleHref(pi, bi, dayIndex)}
                      data-first={first}
                      data-last={last}
                    >
                      <div class={`tx-cyclecard__head${cls}`}>
                        <span>
                          {ui.mesocycleLabel} {mesocycle.index} · {mcLabel(microcycle)}
                        </span>
                        <span>{cycleTotal(microcycle)}</span>
                      </div>
                      {(microcycle.days || []).map((day: PlanDay) => (
                        <div class="tx-daycard">
                          <div class="tx-daycard__date">
                            {fmtShort(day.date)} {weekday(day.date)} · {dayLabel(day.day)}
                          </div>
                          <div class="tx-slot">
                            <div class="tx-slot__label">{ui.am}</div>
                            <div
                              class={`tx-cell tx-cell--${categoryClass(day.am)}`}
                            >
                              {cellText(day.am)}
                            </div>
                          </div>
                          <div class="tx-slot">
                            <div class="tx-slot__label">{ui.pm}</div>
                            <div
                              class={`tx-cell tx-cell--${categoryClass(day.pm)}`}
                            >
                              {cellText(day.pm)}
                            </div>
                          </div>
                        </div>
                      ))}
                    </a>
                  );
                });
              })}
            </div>
          </section>
        );
      })
    }
  </div>
  <div class="tx-weekly"></div>
</div>

<script>
  import { translations, getLocalePath, type Locale } from "@/i18n";
  import {
    todayISO,
    mondayOf,
    fmtShort,
    categoryClass,
    simplifyWorkoutText,
    phases,
    phaseKm,
    phaseKmByCategory,
    calendarMonths,
    weekKm,
    monthKm,
    monthLabel,
    type Workout,
    type CalendarMonth,
  } from "@/utils/training";

  type View = "microcycle" | "weekly";
  type Filter =
    | "none"
    | "regeneration"
    | "fundamental"
    | "special"
    | "specific"
    | "race";

  function init() {
    const app = document.querySelector<HTMLElement>(".tx-app")!;
    if (!app) return; // runtime guard (TS sees app as non-null via the assertion above)
    const lang = (app.dataset.lang as Locale) || "zh-CN";
    const ui = translations[lang].training;

    const state = {
      view: (app.dataset.view as View) || "microcycle",
      filter: (app.dataset.filter as Filter) || "none",
    };
    let weeklyBuilt = false;
    let calMonths: CalendarMonth[] | null = null;

    function renderAttrs() {
      app.dataset.view = state.view;
      app.dataset.filter = state.filter;
    }

    function updateToggleActive() {
      app
        .querySelectorAll<HTMLButtonElement>("[data-view-toggle]")
        .forEach(btn => {
          btn.classList.toggle(
            "tx-tab--active",
            btn.dataset.viewToggle === state.view
          );
        });
      app
        .querySelectorAll<HTMLButtonElement>("button[data-filter-toggle]")
        .forEach(btn => {
          btn.setAttribute(
            "aria-pressed",
            String(btn.dataset.filterToggle === state.filter)
          );
        });
    }

    function dayCellHtml(w: Workout | null): string {
      return `<div class="tx-cell tx-cell--${categoryClass(w)}">${simplifyWorkoutText(w)}</div>`;
    }

    // Build the month-sectioned Mon–Sun calendar (whole plan) into .tx-weekly, once.
    // Each month is its own section: month title (centered over Mon–Sun) + monthly
    // total in the 8th column, a weekday header row, then week rows whose 8th
    // column holds the weekly total. Totals are filled by updateCalendarTotals().
    function buildCalendar() {
      const container = app.querySelector<HTMLElement>(".tx-weekly");
      if (!container) return;
      // Each in-month cell links into the day view via ?date= (the day view's
      // findByDate resolves phase/mesocycle/dayIndex from the ISO date).
      const dayPath = getLocalePath(lang, "running/calendar/day/");
      calMonths = calendarMonths();
      let html = "";
      for (const month of calMonths) {
        html += `<section class="tx-cal__month" data-ym="${month.ym}">`;
        html += `<div class="tx-cal__monthhead">`;
        html += `<div class="tx-cal__monthname">${monthLabel(month.ym, lang)}</div>`;
        html += `<div class="tx-cal__monthtotal"><strong></strong></div>`;
        html += `</div>`;
        html += `<div class="tx-weekly__head">`;
        for (const d of ui.weekdayShort) html += `<div class="tx-weekly__dow">${d}</div>`;
        html += `<div class="tx-weekly__dow"></div>`; // 8th column: no label (alignment only)
        html += `</div>`;
        for (const week of month.weeks) {
          html += `<div class="tx-weekly__week" data-monday="${week.monday}" data-ym="${month.ym}">`;
          for (const cell of week.cells) {
            if (!cell.inMonth || !cell.day) {
              html += '<div class="tx-wkday tx-wkday--empty"></div>';
            } else {
              html +=
                `<a class="tx-wkday" href="${dayPath}?date=${cell.day.date}"><div class="tx-wkday__date">${fmtShort(cell.day.date)}</div>` +
                `${dayCellHtml(cell.day.am)}${dayCellHtml(cell.day.pm)}</a>`;
            }
          }
          html += `<div class="tx-wkday__total"><strong></strong></div>`;
          html += `</div>`;
        }
        html += `</section>`;
      }
      container.innerHTML = html;
      updateCalendarTotals();
    }

    // Fill each month/week total with planned km and a contextual title — all
    // categories, or just the active filter's category (mirrors the phase-header
    // totals). Titles read e.g. "六月第一周 总跑量" / "六月 总跑量", switching the
    // tail to "<category>跑量" when a filter chip is active.
    function updateCalendarTotals() {
      if (!calMonths) return;
      const cat = state.filter === "none" ? undefined : state.filter;
      const catName = state.filter === "none" ? null : FILTER_LABELS[state.filter];
      for (const month of calMonths) {
        const monthEl = app.querySelector<HTMLElement>(
          `.tx-cal__month[data-ym="${month.ym}"]`
        );
        if (!monthEl) continue;
        const mName = monthLabel(month.ym, lang);
        const mCell = monthEl.querySelector<HTMLElement>(".tx-cal__monthtotal");
        if (mCell) {
          mCell.title = ui.monthVolumeTitle(mName, catName);
          const mTotal = mCell.querySelector<HTMLElement>("strong");
          if (mTotal) mTotal.textContent = `${monthKm(month, cat)}km`;
        }
        month.weeks.forEach((week, i) => {
          const wCell = monthEl.querySelector<HTMLElement>(
            `.tx-weekly__week[data-monday="${week.monday}"] .tx-wkday__total`
          );
          if (!wCell) return;
          wCell.title = ui.weekVolumeTitle(mName, i + 1, catName);
          const wTotal = wCell.querySelector<HTMLElement>("strong");
          if (wTotal) wTotal.textContent = `${weekKm(week, cat)}km`;
        });
      }
    }

    // Display name for each filter value (chips + phase header reuse these).
    const FILTER_LABELS: Record<Filter, string> = {
      none: ui.filterAll,
      regeneration: ui.filterRegeneration,
      fundamental: ui.filterFundamental,
      special: ui.filterSpecial,
      specific: ui.filterSpecific,
      race: ui.filterRace,
    };

    // Swap each phase header total: full planned volume when no filter is
    // active, or the active category's volume behind a colored chip otherwise.
    function updatePhaseTotals() {
      phases().forEach((phase, pi) => {
        const total = app.querySelector<HTMLElement>(
          `#phase-${pi + 1} .tx-phase__total`
        );
        if (!total) return;
        if (state.filter === "none") {
          total.innerHTML = `${ui.plannedVolume} <strong>${phaseKm(phase)}km</strong>`;
        } else {
          const km = phaseKmByCategory(phase, state.filter);
          total.innerHTML = `<div class="tx-chip" data-filter-toggle="${state.filter}">${FILTER_LABELS[state.filter]}</div> ${ui.volumeLabel} <strong>${km}km</strong>`;
        }
      });
    }

    // Apply state -> DOM, wrapped in a View Transition when available.
    function commit() {
      if (state.view === "weekly" && !weeklyBuilt) {
        buildCalendar();
        weeklyBuilt = true;
      }
      renderAttrs();
      updateToggleActive();
      updatePhaseTotals();
      updateCalendarTotals();
    }

    function applyState(next: Partial<typeof state>) {
      Object.assign(state, next);
      if (typeof document.startViewTransition === "function") {
        document.startViewTransition(commit);
      } else {
        commit(); // Firefox / older browsers: instant
      }
    }

    // Scroll an element to offsetRem below the viewport top (JS-controlled,
    // so different triggers can use different gaps).
    function scrollToEl(el: HTMLElement, offsetRem: number) {
      const rootPx = parseFloat(
        getComputedStyle(document.documentElement).fontSize
      );
      window.scrollTo({
        top:
          window.scrollY + el.getBoundingClientRect().top - offsetRem * rootPx,
        behavior: "smooth",
      });
    }

    function jumpToCurrent() {
      const today = todayISO();
      if (state.view === "weekly") {
        const ym = today.slice(0, 7);
        const wk = app.querySelector<HTMLElement>(
          `.tx-cal__month[data-ym="${ym}"] .tx-weekly__week[data-monday="${mondayOf(today)}"]`
        );
        if (wk) scrollToEl(wk, 0.15); // tight: single week, minimal gap
        return;
      }
      const mesocycles = Array.from(
        app.querySelectorAll<HTMLElement>("[data-first][data-last]")
      );
      const match = mesocycles.find(
        el =>
          el.dataset.first &&
          el.dataset.last &&
          el.dataset.first <= today &&
          today <= el.dataset.last
      );
      if (!match) return;
      const target =
        mesocycles.find(
          el =>
            el.dataset.first === match.dataset.first &&
            el.dataset.last === match.dataset.last &&
            el.offsetParent !== null
        ) || match;
      target.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    app
      .querySelectorAll<HTMLButtonElement>("[data-view-toggle]")
      .forEach(btn => {
        btn.addEventListener("click", () =>
          applyState({ view: btn.dataset.viewToggle as View })
        );
      });
    app
      .querySelectorAll<HTMLButtonElement>("button[data-filter-toggle]")
      .forEach(btn => {
        btn.addEventListener("click", () => {
          const filter = btn.dataset.filterToggle as Filter;
          applyState({ filter });
          if (filter !== "none") {
            // after the VT, scroll to the first visible cell of this category
            setTimeout(() => {
              const cell = Array.from(
                app.querySelectorAll<HTMLElement>(`.tx-cell--${filter}`)
              ).find(c => c.offsetParent !== null);
              if (!cell) return;
              if (state.view === "microcycle") {
                // scroll to the mesocycle containing the first match, 1rem gap
                const mesocycle = cell.closest<HTMLElement>(".tx-table");
                if (mesocycle) scrollToEl(mesocycle, 1);
              } else {
                // weekly: scroll to the week row containing the first match, 0.15rem gap
                const week = cell.closest<HTMLElement>(".tx-weekly__week");
                if (week) scrollToEl(week, 0.15);
              }
            }, 400);
          }
        });
      });
    // click a mesocycle table → navigate to the mesocycle view
    app.querySelectorAll<HTMLElement>(".tx-table").forEach(el => {
      el.addEventListener("click", () => {
        if (el.dataset.href) location.href = el.dataset.href;
      });
    });
    document.getElementById("tx-current")?.addEventListener("click", e => {
      e.preventDefault();
      jumpToCurrent();
    });
    document.getElementById("tx-current-wk")?.addEventListener("click", e => {
      e.preventDefault();
      jumpToCurrent();
    });
    // phase tabs: clear filter if active, then scroll (weekly) or anchor (microcycle)
    app
      .querySelectorAll<HTMLAnchorElement>('a[href^="#phase-"]')
      .forEach(btn => {
        btn.addEventListener("click", e => {
          const hadFilter = state.filter !== "none";
          if (hadFilter) applyState({ filter: "none" });
          if (state.view !== "weekly") return; // microcycle: native anchor works
          e.preventDefault();
          const phaseEl = document.getElementById(
            btn.getAttribute("href")!.slice(1)
          );
          const firstDate =
            phaseEl?.querySelector<HTMLElement>(".tx-table")?.dataset.first;
          if (!firstDate) return;
          // The week containing the phase's first day, in that day's month section.
          const week = app.querySelector<HTMLElement>(
            `.tx-cal__month[data-ym="${firstDate.slice(0, 7)}"] .tx-weekly__week[data-monday="${mondayOf(firstDate)}"]`
          );
          if (week) {
            if (hadFilter) setTimeout(() => scrollToEl(week, 0.15), 400);
            else scrollToEl(week, 0.15);
          }
        });
      });
    // month tabs: scroll to the month in the current view
    app.querySelectorAll<HTMLAnchorElement>("[data-month]").forEach(btn => {
      btn.addEventListener("click", e => {
        e.preventDefault();
        const ym = btn.dataset.month!;
        if (state.view === "weekly") {
          const monthEl = app.querySelector<HTMLElement>(
            `.tx-cal__month[data-ym="${ym}"]`
          );
          if (monthEl) scrollToEl(monthEl, 1); // gap to show the month title
        } else {
          const ms = `${ym}-01`;
          Array.from(app.querySelectorAll<HTMLElement>(".tx-table"))
            .find(el => el.dataset.first! <= ms && ms <= el.dataset.last!)
            ?.scrollIntoView({ behavior: "smooth", block: "start" });
        }
      });
    });
  }

  document.addEventListener("astro:after-swap", init);
  init();
</script>
