---
import "@/styles/training.css";
import { translations } from "@/i18n";
import type { Locale } from "@/i18n";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const ui = translations[lang].training;
---

<div class="tx-app" id="tx-day" data-lang={lang}>
  <h1 class="text-xl font-semibold tracking-wide sm:text-2xl">{ui.dayTitle}</h1>

  <div class="tx-nav">
    <button class="tx-navbtn" id="tx-prev" aria-label={ui.prevDay}>‹</button>
    <div
      class="tx-pos"
      id="tx-pos"
      role="button"
      tabindex="0"
      aria-label={ui.mesocycleTitle}
    >
      <div class="tx-pos__t" id="tx-title"></div>
      <div class="tx-pos__d" id="tx-date"></div>
    </div>
    <button class="tx-navbtn" id="tx-next" aria-label={ui.nextDay}>›</button>
  </div>

  <section class="tx-section">
    <div class="tx-section__head">
      {ui.plannedSection}<span class="sub">{ui.plannedSectionSub}</span>
    </div>
    <div class="tx-workouts" id="tx-plan"></div>
  </section>

  <section class="tx-section">
    <div class="tx-section__head">
      {ui.actualSection}<span class="sub">{ui.actualSectionSub}</span>
    </div>
    <div class="tx-workouts" id="tx-actual"></div>
  </section>
</div>

<script>
  import { translations } from "@/i18n";
  import type { Locale } from "@/i18n";
  import {
    phases,
    microcycleIndex,
    dayEntriesOf,
    paceOf,
    paceText,
    paceZone,
    parseTargetPace,
    fmtFull,
    findToday,
    todayISO,
    categoryClass,
    esc,
    type Activity,
    type Workout,
    type Split,
  } from "@/utils/training";

  let controller: AbortController | null = null;
  let keyHandler: ((e: KeyboardEvent) => void) | null = null;

  function init() {
    const root = document.getElementById("tx-day");
    if (!root) return;

    // Cancel any in-flight activities fetch + stale key listener from a prior mount.
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    const lang = (root.dataset.lang as Locale) || "zh-CN";
    const base = lang === "zh-CN" ? "" : "/en";
    const ui = translations[lang].training;

    const phaseList = phases();
    let phaseIndex = 0;
    let mesocycleIndex = 0;
    let dayIndex = 0;
    let acts: Activity[] = [];

    const mesocycle = () => phaseList[phaseIndex].mesocycles[mesocycleIndex];
    const entries = () => dayEntriesOf(mesocycle());
    const $ = (id: string) => document.getElementById(id);

    function findByDate(dateStr: string) {
      for (let p = 0; p < phaseList.length; p++) {
        for (let b = 0; b < phaseList[p].mesocycles.length; b++) {
          const ents = dayEntriesOf(phaseList[p].mesocycles[b]);
          for (let di = 0; di < ents.length; di++) {
            if (ents[di].day.date === dateStr) {
              return { phaseIndex: p, mesocycleIndex: b, dayIndex: di };
            }
          }
        }
      }
      return null;
    }

    function applyRoute() {
      const params = new URLSearchParams(location.search);
      // ?date=YYYY-MM-DD (ISO) takes precedence: jump to that day if it's in
      // the plan; otherwise fall back to today.
      const dateParam = params.get("date");
      if (dateParam) {
        const found = findByDate(dateParam);
        if (found) {
          phaseIndex = found.phaseIndex;
          mesocycleIndex = found.mesocycleIndex;
          dayIndex = found.dayIndex;
        } else {
          const td = findToday();
          if (td) {
            phaseIndex = td.phaseIndex;
            mesocycleIndex = td.mesocycleIndex;
            dayIndex = td.dayIndex;
          }
        }
        return;
      }
      const p = Number.parseInt(params.get("phase") || "", 10);
      if (Number.isInteger(p) && p >= 0 && p < phaseList.length) phaseIndex = p;
      const b = Number.parseInt(params.get("mesocycle") || "", 10);
      if (
        Number.isInteger(b) &&
        b >= 0 &&
        b < phaseList[phaseIndex].mesocycles.length
      )
        mesocycleIndex = b;
      const list = entries();
      const d = Number.parseInt(params.get("day") || "", 10);
      if (Number.isInteger(d) && d >= 0 && d < list.length) dayIndex = d;
    }

    function step(delta: number) {
      // Cross mesocycle/phase boundaries so "next day" is always the real next
      // calendar day (the plan is contiguous: each mesocycle's day 0 follows the
      // previous mesocycle's last day). Previously this wrapped within the current
      // mesocycle, so the last day of a mesocycle jumped back to its first day.
      const ni = dayIndex + delta;
      if (ni >= entries().length) {
        mesocycleIndex++;
        if (mesocycleIndex >= phaseList[phaseIndex].mesocycles.length) {
          mesocycleIndex = 0;
          phaseIndex = (phaseIndex + 1) % phaseList.length;
        }
        dayIndex = 0;
      } else if (ni < 0) {
        mesocycleIndex--;
        if (mesocycleIndex < 0) {
          phaseIndex = (phaseIndex - 1 + phaseList.length) % phaseList.length;
          mesocycleIndex = phaseList[phaseIndex].mesocycles.length - 1;
        }
        dayIndex = entries().length - 1;
      } else {
        dayIndex = ni;
      }
      render();
    }

    function goMesocycle() {
      location.href = `${base}/running/calendar/mesocycle/?phase=${phaseIndex}&mesocycle=${mesocycleIndex}&day=${dayIndex}`;
    }

    function planBoxHtml(w: Workout | null, label: string): string {
      if (!w || !w.text) {
        return `<div class="tx-workout tx-workout--rest"><div class="tx-workout__period">${label}</div><div class="tx-workout__title">${ui.rest}</div></div>`;
      }
      return `<div class="tx-workout tx-workout--${categoryClass(w)}"><div class="tx-workout__period">${label} · ${ui.plannedKm(w.planned_km || 0)}</div><div class="tx-workout__title">${esc(w.text)}</div></div>`;
    }

    // Catmull-Rom → cubic Bézier: a smooth path through every point.
    function smoothPath(points: [number, number][]): string {
      if (!points.length) return "";
      if (points.length < 3)
        return `M${points[0][0]},${points[0][1]}` +
          (points[1] ? ` L${points[1][0]},${points[1][1]}` : "");
      let d = `M${points[0][0]},${points[0][1]}`;
      for (let i = 0; i < points.length - 1; i++) {
        const p0 = points[i - 1] || points[i];
        const p1 = points[i];
        const p2 = points[i + 1];
        const p3 = points[i + 2] || p2;
        const c1x = p1[0] + (p2[0] - p0[0]) / 6;
        const c1y = p1[1] + (p2[1] - p0[1]) / 6;
        const c2x = p2[0] - (p3[0] - p1[0]) / 6;
        const c2y = p2[1] - (p3[1] - p1[1]) / 6;
        d += ` C${c1x.toFixed(1)},${c1y.toFixed(1)} ${c2x.toFixed(1)},${c2y.toFixed(1)} ${p2[0].toFixed(1)},${p2[1].toFixed(1)}`;
      }
      return d;
    }

    function paceChartHtml(w: Workout | null, splits: Split[]): string {
      // Bars = the PLAN target (a zone-colored band: light fill below the target,
      // darker band across the target range). Line = the ACTUAL per-km pace, as a
      // smooth curve. x = cumulative moving_time; y = pace (faster = lower).
      // drop GPS fragments (partial km < 0.5) — their pace is noise and they
      // distort the curve (e.g. a 0.035km/17s tail split reporting 8′08″/km).
      const valid = (splits || []).filter(
        x =>
          x &&
          x.pace_sec_per_km &&
          x.moving_time &&
          (x.distance_km ?? 1) >= 0.5
      );
      if (!valid.length) return "";
      // Regeneration (recovery) sessions carry no @pace — they're all Z1, so
      // infer a Z1 target (≥ 5′09″/km, open-ended up) to draw their plan rect too.
      const Z1_CEIL = 310; // 5′09″, the Z1/Z2 boundary
      let target = parseTargetPace(w?.text);
      if (!target && w != null && categoryClass(w) === "regeneration") {
        target = { fast: Z1_CEIL, slow: Infinity };
      }

      let cum = 0;
      const pts = valid.map(s => {
        const start = cum;
        const wid = s.moving_time as number;
        cum += wid;
        return {
          start,
          w: wid,
          pace: s.pace_sec_per_km as number,
          n: s.split ?? 0,
        };
      });
      const total = cum;

      // The plan rectangle spans the PLANNED duration (planned_km × target pace),
      // not the full actual time — run longer and the curve extends past the rect.
      const planPace = target
        ? Number.isFinite(target.slow)
          ? (target.fast + target.slow) / 2
          : target.fast
        : null;
      const plannedDur =
        target && w?.planned_km && planPace ? w.planned_km * planPace : null;
      const planW = plannedDur ?? total; // plan rectangle width (fallback: full)
      const viewW = Math.max(total, planW); // viewBox spans whichever is longer

      // y-domain covers actual paces + the plan target range
      const vals: number[] = pts.map(p => p.pace);
      if (target) {
        vals.push(target.fast);
        if (Number.isFinite(target.slow)) vals.push(target.slow);
      }
      const fastest = Math.min(...vals);
      const slowest = Math.max(...vals);
      const span = slowest - fastest;
      let pMin = fastest - Math.max(8, span * 0.12);
      let pMax = slowest + Math.max(8, span * 0.12);
      if (pMax - pMin < 16) {
        const c = (pMin + pMax) / 2;
        pMin = c - 8;
        pMax = c + 8;
      }
      pMin = Math.max(0, pMin);

      const H = 80; // viewBox height (user units); CSS height 5rem
      const yOf = (pace: number) => (H * (pace - pMin)) / (pMax - pMin); // faster → smaller y → top

      // plan target: light base (baseline→fast bound) + darker band across the
      // target range (fast→slow); a single pace draws a crisp line instead.
      let plan = "";
      const tz = target ? paceZone(target.fast) : null;
      const rngLabel = target
        ? Number.isFinite(target.slow)
          ? `${paceText(target.fast)}–${paceText(target.slow)}`
          : `>${paceText(target.fast)}`
        : "";
      if (target && tz) {
        const yFast = yOf(target.fast);
        const ySlow = Number.isFinite(target.slow) ? yOf(target.slow) : H; // ∞ → bottom
        // light base: top edge down to the fast bound (faster-than-target)
        plan = `<rect class="tx-pace__plan-base" style="--zc:${tz.color}" x="0" y="0" width="${planW}" height="${yFast.toFixed(1)}"/>`;
        if (target.slow > target.fast) {
          // dark band across the target range (fast → slow)
          plan += `<rect class="tx-pace__plan-zone" style="--zc:${tz.color}" x="0" y="${yFast.toFixed(1)}" width="${planW}" height="${(ySlow - yFast).toFixed(1)}"><title>${ui.plannedSection} Z${tz.id} ${rngLabel}/km</title></rect>`;
        } else {
          plan += `<line class="tx-pace__plan-line" style="--zc:${tz.color}" x1="0" x2="${planW}" y1="${yFast.toFixed(1)}" y2="${yFast.toFixed(1)}"><title>${ui.plannedSection} Z${tz.id} ${rngLabel}/km</title></line>`;
        }
      }

      // actual: smooth curve from the left edge (x=0, at the first km's pace)
      // through each km to the right edge (x=total); no per-km dots.
      const centers: [number, number][] = pts.map(p => [
        p.start + p.w / 2,
        yOf(p.pace),
      ]);
      const curvePts: [number, number][] = centers.length
        ? [
            [0, centers[0][1]],
            ...centers,
            [total, centers[centers.length - 1][1]],
          ]
        : [];
      const curve =
        curvePts.length > 1
          ? `<path class="tx-pace__line" d="${smoothPath(curvePts)}"/>`
          : "";

      // y-axis pace labels: fastest (top) · mid · slowest (bottom)
      const midPace = Math.round((fastest + slowest) / 2);
      const scale = `<span>${paceText(Math.round(fastest))}</span><span>${paceText(midPace)}</span><span>${paceText(Math.round(slowest))}</span>`;

      const fmtT = (sec: number) => {
        const m = Math.floor(sec / 60),
          s = Math.round(sec % 60);
        return `${m}:${s < 10 ? "0" : ""}${s}`;
      };
      const xticks = [0, 0.25, 0.5, 0.75, 1]
        .map(frac => {
          const tx = frac === 0 ? "0" : frac === 1 ? "-100%" : "-50%";
          return `<span class="tx-pace__tick" style="left:${(frac * 100).toFixed(2)}%; transform:translateX(${tx})">${fmtT(frac * viewW)}</span>`;
        })
        .join("");

      // legend: plan target zone (+ range) · actual pace range
      const legend: string[] = [];
      if (target && tz) {
        legend.push(
          `<span class="tx-pace__lg"><i class="tx-pace__sw" style="--zc:${tz.color}"></i>${ui.plannedSection} Z${tz.id} ${rngLabel}/km</span>`
        );
      }
      const aFast = Math.min(...pts.map(p => p.pace));
      const aSlow = Math.max(...pts.map(p => p.pace));
      legend.push(
        `<span class="tx-pace__lg"><i class="tx-pace__ln"></i>${ui.actualSection} ${paceText(Math.round(aFast))}–${paceText(Math.round(aSlow))}/km</span>`
      );

      return `<div class="tx-pace" aria-label="${ui.paceFastest(paceText(Math.round(aFast)))}，${ui.paceSlowest(paceText(Math.round(aSlow)))}">
        <div class="tx-pace__plot">
          <div class="tx-pace__scale">${scale}</div>
          <svg class="tx-pace__svg" viewBox="0 0 ${viewW} ${H}" preserveAspectRatio="none" role="img">${plan}${curve}</svg>
        </div>
        <div class="tx-pace__xaxis">${xticks}</div>
        <div class="tx-pace__legend">${legend.join("")}</div>
      </div>`;
    }

    function activityBoxHtml(w: Workout | null, act: Activity, label: string): string {
      const extra =
        !w || !w.text
          ? `<span class="tx-tag tx-tag--extra">${ui.extra}</span>`
          : "";
      const cat = categoryClass(w);
      const p = paceOf(act.distance_km, act.moving_time);
      const desc = (act.description || "").trim();
      const meta = desc
        ? `<div class="tx-workout__meta">${esc(desc)}</div>`
        : "";
      const inner = `<div class="tx-workout__period">${label}${extra}</div>
          <div class="tx-workout__title">✓ ${act.distance_km}km${p ? " @ " + p : ""}</div>${meta}${paceChartHtml(w, act.splits_metric || [])}`;
      if (act.id) {
        return `<a class="tx-workout tx-workout--${cat} tx-workout--done" href="https://www.strava.com/activities/${act.id}" target="_blank" rel="noopener">${inner}</a>`;
      }
      return `<div class="tx-workout tx-workout--${cat} tx-workout--done">${inner}</div>`;
    }

    function actualSlotsHtml(w: Workout | null, periodActs: Activity[], label: string, pendingLabel: string): string {
      if (periodActs.length > 0) {
        return periodActs.map(a => activityBoxHtml(w, a, label)).join("");
      }
      if (!w || !w.text) {
        return `<div class="tx-workout tx-workout--rest"><div class="tx-workout__period">${label}</div><div class="tx-workout__title">${ui.rest}</div></div>`;
      }
      return `<div class="tx-workout tx-workout--${categoryClass(w)}"><div class="tx-workout__period">${label}</div><div class="tx-workout__title">${pendingLabel}</div></div>`;
    }

    function render() {
      const planEl = $("tx-plan");
      if (!planEl) return;
      const list = entries();
      if (dayIndex >= list.length) dayIndex = 0;
      const { microcycle, day } = list[dayIndex];
      // Breadcrumb tail: Today if the shown day is today, else Day (SSR defaults to Today).
      const crumb = document.querySelector(
        'nav[aria-label="breadcrumb"] [aria-current="page"]'
      );
      if (crumb) crumb.textContent = day.date === todayISO() ? "Today" : "Day";
      const tag = microcycle.taper
        ? `<span class="tx-tag tx-tag--taper">${ui.taper}</span>`
        : microcycle.cutback
          ? `<span class="tx-tag tx-tag--cutback">${ui.cutback}</span>`
          : "";
      const phaseName =
        (ui.phaseLabels as Record<string, string>)[phaseList[phaseIndex].name] ??
        phaseList[phaseIndex].name.replace(" Session", " Phase");
      const dayName = lang === "zh-CN" ? `第${day.day}天` : `Day ${day.day}`;
      $("tx-title")!.innerHTML =
        `${phaseName} · ${ui.microcycleLabel} ${microcycleIndex(microcycle)} · ${dayName} ${tag}`;
      $("tx-date")!.textContent = fmtFull(day.date);
      const amActs = acts.filter(
        a => a.date === day.date && parseInt((a.time || "12").slice(0, 2)) < 12
      );
      const pmActs = acts.filter(
        a => a.date === day.date && parseInt((a.time || "12").slice(0, 2)) >= 12
      );
      const pendingLabel = todayISO() > day.date ? ui.incomplete : ui.pending;
      planEl.innerHTML =
        planBoxHtml(day.am, ui.am) + planBoxHtml(day.pm, ui.pm);
      $("tx-actual")!.innerHTML =
        actualSlotsHtml(day.am, amActs, ui.am, pendingLabel) +
        actualSlotsHtml(day.pm, pmActs, ui.pm, pendingLabel);
    }

    // wire navigation
    $("tx-prev")!.onclick = () => step(-1);
    $("tx-next")!.onclick = () => step(1);
    const pos = $("tx-pos")!;
    pos.onclick = goMesocycle;
    pos.onkeydown = e => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        goMesocycle();
      }
    };

    if (keyHandler) document.removeEventListener("keydown", keyHandler);
    keyHandler = (e: KeyboardEvent) => {
      if (!document.getElementById("tx-day")) return;
      if (e.key === "ArrowLeft") step(-1);
      if (e.key === "ArrowRight") step(1);
    };
    document.addEventListener("keydown", keyHandler);

    applyRoute();
    if (!location.search) {
      const td = findToday();
      if (td) {
        phaseIndex = td.phaseIndex;
        mesocycleIndex = td.mesocycleIndex;
        dayIndex = td.dayIndex;
      }
    }

    // Render immediately with no actuals, then hydrate once activities arrive.
    render();
    fetch("/running/calendar/activities.json", { signal })
      .then(r => (r.ok ? r.json() : []))
      .then((data: Activity[] | Activity) => {
        if (signal.aborted) return;
        acts = Array.isArray(data) ? data : [];
        render();
      })
      .catch(() => {
        if (!signal.aborted) render();
      });
  }

  document.addEventListener("astro:after-swap", init);
  init();
</script>
