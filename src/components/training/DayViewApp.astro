---
import "@/styles/training.css";
import { translations } from "@/i18n";
import type { Locale } from "@/i18n";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const ui = translations[lang].training;
---

<div class="tx-app" id="tx-day" data-lang={lang}>
  <h1 class="text-xl font-semibold tracking-wide sm:text-2xl">{ui.dayTitle}</h1>

  <div class="tx-nav">
    <button class="tx-navbtn" id="tx-prev" aria-label={ui.prevDay}>‹</button>
    <div
      class="tx-pos"
      id="tx-pos"
      role="button"
      tabindex="0"
      aria-label={ui.mesocycleTitle}
    >
      <div class="tx-pos__t" id="tx-title"></div>
      <div class="tx-pos__d" id="tx-date"></div>
    </div>
    <button class="tx-navbtn" id="tx-next" aria-label={ui.nextDay}>›</button>
  </div>

  <section class="tx-section">
    <div class="tx-section__head">
      {ui.plannedSection}<span class="sub">{ui.plannedSectionSub}</span>
    </div>
    <div class="tx-workouts" id="tx-plan"></div>
  </section>

  <section class="tx-section">
    <div class="tx-section__head">
      {ui.actualSection}<span class="sub">{ui.actualSectionSub}</span>
    </div>
    <div class="tx-workouts" id="tx-actual"></div>
  </section>
</div>

<script>
  import { translations } from "@/i18n";
  import type { Locale } from "@/i18n";
  import {
    phases,
    microcycleIndex,
    dayEntriesOf,
    paceOf,
    paceText,
    fmtFull,
    findToday,
    todayISO,
    categoryClass,
    esc,
    type Activity,
    type Workout,
    type Split,
  } from "@/utils/training";

  let controller: AbortController | null = null;
  let keyHandler: ((e: KeyboardEvent) => void) | null = null;

  function init() {
    const root = document.getElementById("tx-day");
    if (!root) return;

    // Cancel any in-flight activities fetch + stale key listener from a prior mount.
    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    const lang = (root.dataset.lang as Locale) || "zh-CN";
    const base = lang === "zh-CN" ? "" : "/en";
    const ui = translations[lang].training;

    const phaseList = phases();
    let phaseIndex = 0;
    let mesocycleIndex = 0;
    let dayIndex = 0;
    let acts: Activity[] = [];

    const mesocycle = () => phaseList[phaseIndex].mesocycles[mesocycleIndex];
    const entries = () => dayEntriesOf(mesocycle());
    const $ = (id: string) => document.getElementById(id);

    function findByDate(dateStr: string) {
      for (let p = 0; p < phaseList.length; p++) {
        for (let b = 0; b < phaseList[p].mesocycles.length; b++) {
          const ents = dayEntriesOf(phaseList[p].mesocycles[b]);
          for (let di = 0; di < ents.length; di++) {
            if (ents[di].day.date === dateStr) {
              return { phaseIndex: p, mesocycleIndex: b, dayIndex: di };
            }
          }
        }
      }
      return null;
    }

    function applyRoute() {
      const params = new URLSearchParams(location.search);
      // ?date=YYYY-MM-DD (ISO) takes precedence: jump to that day if it's in
      // the plan; otherwise fall back to today.
      const dateParam = params.get("date");
      if (dateParam) {
        const found = findByDate(dateParam);
        if (found) {
          phaseIndex = found.phaseIndex;
          mesocycleIndex = found.mesocycleIndex;
          dayIndex = found.dayIndex;
        } else {
          const td = findToday();
          if (td) {
            phaseIndex = td.phaseIndex;
            mesocycleIndex = td.mesocycleIndex;
            dayIndex = td.dayIndex;
          }
        }
        return;
      }
      const p = Number.parseInt(params.get("phase") || "", 10);
      if (Number.isInteger(p) && p >= 0 && p < phaseList.length) phaseIndex = p;
      const b = Number.parseInt(params.get("mesocycle") || "", 10);
      if (
        Number.isInteger(b) &&
        b >= 0 &&
        b < phaseList[phaseIndex].mesocycles.length
      )
        mesocycleIndex = b;
      const list = entries();
      const d = Number.parseInt(params.get("day") || "", 10);
      if (Number.isInteger(d) && d >= 0 && d < list.length) dayIndex = d;
    }

    function step(delta: number) {
      // Cross mesocycle/phase boundaries so "next day" is always the real next
      // calendar day (the plan is contiguous: each mesocycle's day 0 follows the
      // previous mesocycle's last day). Previously this wrapped within the current
      // mesocycle, so the last day of a mesocycle jumped back to its first day.
      const ni = dayIndex + delta;
      if (ni >= entries().length) {
        mesocycleIndex++;
        if (mesocycleIndex >= phaseList[phaseIndex].mesocycles.length) {
          mesocycleIndex = 0;
          phaseIndex = (phaseIndex + 1) % phaseList.length;
        }
        dayIndex = 0;
      } else if (ni < 0) {
        mesocycleIndex--;
        if (mesocycleIndex < 0) {
          phaseIndex = (phaseIndex - 1 + phaseList.length) % phaseList.length;
          mesocycleIndex = phaseList[phaseIndex].mesocycles.length - 1;
        }
        dayIndex = entries().length - 1;
      } else {
        dayIndex = ni;
      }
      render();
    }

    function goMesocycle() {
      location.href = `${base}/running/calendar/mesocycle/?phase=${phaseIndex}&mesocycle=${mesocycleIndex}&day=${dayIndex}`;
    }

    function planBoxHtml(w: Workout | null, label: string): string {
      if (!w || !w.text) {
        return `<div class="tx-workout tx-workout--rest"><div class="tx-workout__period">${label}</div><div class="tx-workout__title">${ui.rest}</div></div>`;
      }
      return `<div class="tx-workout tx-workout--${categoryClass(w)}"><div class="tx-workout__period">${label} · ${ui.plannedKm(w.planned_km || 0)}</div><div class="tx-workout__title">${esc(w.text)}</div></div>`;
    }

    function paceChartHtml(splits: Split[]): string {
      const valid = (splits || []).filter(x => x && x.pace_sec_per_km);
      if (!valid.length) return "";
      const paces = valid.map(x => x.pace_sec_per_km as number);
      const fastest = Math.min(...paces);
      const slowest = Math.max(...paces);
      const mid = Math.round((fastest + slowest) / 2);
      const spread = Math.max(1, slowest - fastest);
      const bars = valid
        .map((split, i) => {
          const speedScore =
            (slowest - (split.pace_sec_per_km as number)) / spread;
          const h = Math.round(24 + speedScore * 54);
          const label = split.split || i + 1;
          const title = `${ui.dayLabel} ${label} km：${paceText(split.pace_sec_per_km as number)}/km`;
          return `<div class="tx-pace__bar" style="height:${h}px" title="${title}" aria-label="${title}"><span>${label}</span></div>`;
        })
        .join("");
      return `<div class="tx-pace" aria-label="${ui.paceFastest(paceText(fastest))}，${ui.paceSlowest(paceText(slowest))}">
        <div class="tx-pace__plot">
          <div class="tx-pace__scale"><span>${paceText(fastest)}</span><span>${paceText(mid)}</span><span>${paceText(slowest)}</span></div>
          <div class="tx-pace__bars">${bars}</div>
        </div>
        <div class="tx-pace__caption"><span>${ui.paceFastest(paceText(fastest))}</span><span>${ui.paceSlowest(paceText(slowest))}</span></div>
      </div>`;
    }

    function activityBoxHtml(w: Workout | null, act: Activity, label: string): string {
      const extra =
        !w || !w.text
          ? `<span class="tx-tag tx-tag--extra">${ui.extra}</span>`
          : "";
      const cat = categoryClass(w);
      const p = paceOf(act.distance_km, act.moving_time);
      const desc = (act.description || "").trim();
      const meta = desc
        ? `<div class="tx-workout__meta">${esc(desc)}</div>`
        : "";
      const inner = `<div class="tx-workout__period">${label}${extra}</div>
          <div class="tx-workout__title">✓ ${act.distance_km}km${p ? " @ " + p : ""}</div>${meta}${paceChartHtml(act.splits_metric || [])}`;
      if (act.id) {
        return `<a class="tx-workout tx-workout--${cat} tx-workout--done" href="https://www.strava.com/activities/${act.id}" target="_blank" rel="noopener">${inner}</a>`;
      }
      return `<div class="tx-workout tx-workout--${cat} tx-workout--done">${inner}</div>`;
    }

    function actualSlotsHtml(w: Workout | null, periodActs: Activity[], label: string, pendingLabel: string): string {
      if (periodActs.length > 0) {
        return periodActs.map(a => activityBoxHtml(w, a, label)).join("");
      }
      if (!w || !w.text) {
        return `<div class="tx-workout tx-workout--rest"><div class="tx-workout__period">${label}</div><div class="tx-workout__title">${ui.rest}</div></div>`;
      }
      return `<div class="tx-workout tx-workout--${categoryClass(w)}"><div class="tx-workout__period">${label}</div><div class="tx-workout__title">${pendingLabel}</div></div>`;
    }

    function render() {
      const planEl = $("tx-plan");
      if (!planEl) return;
      const list = entries();
      if (dayIndex >= list.length) dayIndex = 0;
      const { microcycle, day } = list[dayIndex];
      // Breadcrumb tail: Today if the shown day is today, else Day (SSR defaults to Today).
      const crumb = document.querySelector(
        'nav[aria-label="breadcrumb"] [aria-current="page"]'
      );
      if (crumb) crumb.textContent = day.date === todayISO() ? "Today" : "Day";
      const tag = microcycle.taper
        ? `<span class="tx-tag tx-tag--taper">${ui.taper}</span>`
        : microcycle.cutback
          ? `<span class="tx-tag tx-tag--cutback">${ui.cutback}</span>`
          : "";
      const phaseName =
        (ui.phaseLabels as Record<string, string>)[phaseList[phaseIndex].name] ??
        phaseList[phaseIndex].name.replace(" Session", " Phase");
      const dayName = lang === "zh-CN" ? `第${day.day}天` : `Day ${day.day}`;
      $("tx-title")!.innerHTML =
        `${phaseName} · ${ui.microcycleLabel} ${microcycleIndex(microcycle)} · ${dayName} ${tag}`;
      $("tx-date")!.textContent = fmtFull(day.date);
      const amActs = acts.filter(
        a => a.date === day.date && parseInt((a.time || "12").slice(0, 2)) < 12
      );
      const pmActs = acts.filter(
        a => a.date === day.date && parseInt((a.time || "12").slice(0, 2)) >= 12
      );
      const pendingLabel = todayISO() > day.date ? ui.incomplete : ui.pending;
      planEl.innerHTML =
        planBoxHtml(day.am, ui.am) + planBoxHtml(day.pm, ui.pm);
      $("tx-actual")!.innerHTML =
        actualSlotsHtml(day.am, amActs, ui.am, pendingLabel) +
        actualSlotsHtml(day.pm, pmActs, ui.pm, pendingLabel);
    }

    // wire navigation
    $("tx-prev")!.onclick = () => step(-1);
    $("tx-next")!.onclick = () => step(1);
    const pos = $("tx-pos")!;
    pos.onclick = goMesocycle;
    pos.onkeydown = e => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        goMesocycle();
      }
    };

    if (keyHandler) document.removeEventListener("keydown", keyHandler);
    keyHandler = (e: KeyboardEvent) => {
      if (!document.getElementById("tx-day")) return;
      if (e.key === "ArrowLeft") step(-1);
      if (e.key === "ArrowRight") step(1);
    };
    document.addEventListener("keydown", keyHandler);

    applyRoute();
    if (!location.search) {
      const td = findToday();
      if (td) {
        phaseIndex = td.phaseIndex;
        mesocycleIndex = td.mesocycleIndex;
        dayIndex = td.dayIndex;
      }
    }

    // Render immediately with no actuals, then hydrate once activities arrive.
    render();
    fetch("/running/calendar/activities.json", { signal })
      .then(r => (r.ok ? r.json() : []))
      .then((data: Activity[] | Activity) => {
        if (signal.aborted) return;
        acts = Array.isArray(data) ? data : [];
        render();
      })
      .catch(() => {
        if (!signal.aborted) render();
      });
  }

  document.addEventListener("astro:after-swap", init);
  init();
</script>
