---
import "@/styles/training.css";
import { translations } from "@/i18n";
import type { Locale } from "@/i18n";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const ui = translations[lang].training;
---

<div class="tx-app" id="tx-mesocycle" data-lang={lang}>
  <h1 class="text-xl font-semibold tracking-wide sm:text-2xl">
    {ui.mesocycleTitle}
  </h1>

  <div class="tx-nav">
    <button class="tx-navbtn" id="tx-prev" aria-label={ui.prevMesocycle}>‹</button>
    <div
      class="tx-pos"
      id="tx-pos"
      role="button"
      tabindex="0"
      aria-label={ui.dayTitle}
    >
      <div class="tx-pos__t" id="tx-title"></div>
      <div class="tx-pos__d" id="tx-date"></div>
    </div>
    <button class="tx-navbtn" id="tx-next" aria-label={ui.nextMesocycle}>›</button>
  </div>

  <section class="tx-section">
    <div class="tx-section__head">
      <span id="tx-subtitle"></span>
      <span id="tx-meso-total"></span>
    </div>
    <div class="tx-microcycles" id="tx-microcycles"></div>
  </section>
</div>

<script>
  import { translations } from "@/i18n";
  import type { Locale } from "@/i18n";
  import {
    phases,
    microcyclesOf,
    microcycleIndex,
    dayEntriesOf,
    dayPlannedKm,
    aggregateActs,
    categoryClass,
    simplifyWorkoutText,
    fmtShort,
    findToday,
    type Activity,
    type AggregatedActual,
    type PlanDay,
    type Workout,
  } from "@/utils/training";

  let controller: AbortController | null = null;

  function init() {
    const root = document.getElementById("tx-mesocycle");
    if (!root) return;

    controller?.abort();
    controller = new AbortController();
    const { signal } = controller;

    const lang = (root.dataset.lang as Locale) || "zh-CN";
    const base = lang === "zh-CN" ? "" : "/en";
    const ui = translations[lang].training;

    const phaseList = phases();
    let phaseIndex = 0;
    let mesocycleIndex = 0;
    let dayIndex = 0;
    let acts: Activity[] = [];

    const phase = () => phaseList[phaseIndex];
    const mesocycle = () => phase().mesocycles[mesocycleIndex];
    const $ = (id: string) => document.getElementById(id);

    function applyRoute() {
      const params = new URLSearchParams(location.search);
      const p = Number.parseInt(params.get("phase") || "", 10);
      if (Number.isInteger(p) && p >= 0 && p < phaseList.length) phaseIndex = p;
      const b = Number.parseInt(params.get("mesocycle") || "", 10);
      if (Number.isInteger(b) && b >= 0 && b < phase().mesocycles.length)
        mesocycleIndex = b;
      const list = dayEntriesOf(mesocycle());
      const d = Number.parseInt(params.get("day") || "", 10);
      if (Number.isInteger(d) && d >= 0 && d < list.length) dayIndex = d;
    }

    function goDay(index: number) {
      dayIndex = index;
      location.href = `${base}/running/calendar/day/?phase=${phaseIndex}&mesocycle=${mesocycleIndex}&day=${dayIndex}`;
    }

    function stepMesocycle(direction: number) {
      // Cross phase boundaries so "next mesocycle" goes to the real next mesocycle
      // (previously wrapped within the current phase).
      mesocycleIndex += direction;
      if (mesocycleIndex >= phaseList[phaseIndex].mesocycles.length) {
        phaseIndex = (phaseIndex + 1) % phaseList.length;
        mesocycleIndex = 0;
      } else if (mesocycleIndex < 0) {
        phaseIndex = (phaseIndex - 1 + phaseList.length) % phaseList.length;
        mesocycleIndex = phaseList[phaseIndex].mesocycles.length - 1;
      }
      dayIndex = 0;
      render();
    }

    function slotHtml(w: Workout | null, a: AggregatedActual | null): string {
      const plan = w && w.text ? simplifyWorkoutText(w) : a ? ui.rest : "";
      let actual = "";
      if (a) {
        const km = Math.floor(a.km);
        const met = w && w.text ? a.km >= (w.planned_km || 0) : false;
        actual = `<span class="bd-act ${met ? "bd-met" : "bd-miss"}">${km}km ${met ? "✓" : "✗"}</span>`;
      } else if (w && w.text) {
        actual = `<span class="bd-act bd-miss">0km ✗</span>`;
      }
      if (!plan && !actual)
        return `<div class="bd-slot bd-rest">${ui.rest}</div>`;
      const cat = w && w.text ? categoryClass(w) : "extra";
      return `<div class="bd-slot tx-cell--${cat}">${plan}${actual}</div>`;
    }

    function mergeActual(
      am: AggregatedActual | null,
      pm: AggregatedActual | null
    ): AggregatedActual | null {
      if (!am) return pm;
      if (!pm) return am;
      return {
        km: +(am.km + pm.km).toFixed(2),
        t: am.t + pm.t,
        e: am.e + pm.e,
        n: am.n + pm.n,
        name: am.name,
        id: am.id,
        desc: am.desc,
        splits: [...am.splits, ...pm.splits],
      };
    }

    function dayLabel(n: number): string {
      return lang === "zh-CN" ? `第${n}天` : `Day ${n}`;
    }

    function dayButtonHtml(day: PlanDay, indexInMesocycle: number): string {
      const agg = aggregateActs(acts, day.date);
      const hasAm = !!day.am?.text;
      const hasPm = !!day.pm?.text;
      const restSlot = `<div class="bd-slot bd-rest">${ui.rest}</div>`;
      let amSlot: string;
      let pmSlot: string;
      if (hasAm && !hasPm && !agg.am && agg.pm) {
        amSlot = slotHtml(day.am, mergeActual(agg.am, agg.pm));
        pmSlot = restSlot;
      } else if (!hasAm && hasPm && !agg.pm && agg.am) {
        amSlot = restSlot;
        pmSlot = slotHtml(day.pm, mergeActual(agg.am, agg.pm));
      } else {
        amSlot = slotHtml(day.am, agg.am);
        pmSlot = slotHtml(day.pm, agg.pm);
      }
      return `<div class="tx-mesoday" data-day="${indexInMesocycle}">
        <div class="bd-head"><span>${dayLabel(day.day)}</span><span class="bd-date">${fmtShort(day.date)} ${lang === "zh-CN" ? "周" : ""}${ui.weekdayShort[(new Date(day.date + "T00:00:00").getDay() + 6) % 7]}</span></div>
        <div class="bd-plan">${amSlot}${pmSlot}</div>
      </div>`;
    }

    function render() {
      const wrap = $("tx-microcycles");
      if (!wrap) return;
      const currentMesocycle = mesocycle();
      const micros = microcyclesOf(currentMesocycle);
      const list = dayEntriesOf(currentMesocycle);
      const first = list[0]?.day.date;
      const last = list[list.length - 1]?.day.date;
      const phaseName =
        (ui.phaseLabels as Record<string, string>)[phase().name] ??
        phase().name;
      $("tx-title")!.textContent =
        `${phaseName} · ${ui.mesocycleLabel} ${currentMesocycle.index}`;
      $("tx-date")!.textContent =
        first && last ? `${fmtShort(first)} - ${fmtShort(last)}` : "";
      $("tx-subtitle")!.textContent =
        `${micros.length} ${ui.microcycles} · ${list.length} ${ui.days}`;

      // mesocycle-level planned vs actual totals
      const mesocyclePlanned = list.reduce(
        (s, { day }) => s + dayPlannedKm(day),
        0
      );
      const mesocycleActual = list.reduce((s, { day }) => {
        const a = aggregateActs(acts, day.date);
        return s + (a.am?.km || 0) + (a.pm?.km || 0);
      }, 0);
      const mesocycleMet = mesocycleActual >= mesocyclePlanned;
      const mesocycleHasActual = mesocycleActual > 0;
      const mesocycleActualHtml = mesocycleHasActual
        ? `<span class="${mesocycleMet ? "tx-met" : "tx-miss"}"> ${ui.actualLabel} ${Math.floor(mesocycleActual)}km ${mesocycleMet ? "✓" : "✗"}</span>`
        : "";
      $("tx-meso-total")!.innerHTML =
        `${ui.plannedKm(mesocyclePlanned)}${mesocycleActualHtml}`;

      let baseIdx = 0;
      wrap.innerHTML = micros
        .map(microcycle => {
          const days = microcycle.days || [];
          const parsed = parseFloat(microcycle.total_km || "");
          const plannedKm = Number.isNaN(parsed)
            ? days.reduce((s, d) => s + dayPlannedKm(d), 0)
            : parsed;
          const actualKm = days.reduce((s, d) => {
            const a = aggregateActs(acts, d.date);
            return s + (a.am?.km || 0) + (a.pm?.km || 0);
          }, 0);
          const met = actualKm >= plannedKm;
          const hasActual = actualKm > 0;
          const actualHtml = hasActual
            ? `<span class="${met ? "tx-met" : "tx-miss"}"> ${ui.actualLabel} ${Math.floor(actualKm)}km ${met ? "✓" : "✗"}</span>`
            : "";
          const total = `${ui.plannedKm(plannedKm)}${actualHtml}`;
          const tag = microcycle.taper
            ? `<span class="tx-tag tx-tag--taper">${ui.taper}</span>`
            : microcycle.cutback
              ? `<span class="tx-tag tx-tag--cutback">${ui.cutback}</span>`
              : "";
          const buttons = days
            .map((day, i) => dayButtonHtml(day, baseIdx + i))
            .join("");
          baseIdx += days.length;
          return `<div class="tx-microcycle">
            <div class="tx-microcycle__head">
              <div class="tx-microcycle__name">${ui.microcycleLabel} ${microcycleIndex(microcycle)} ${tag}</div>
              <div class="tx-microcycle__total">${total}</div>
            </div>
            <div class="tx-mesodays">${buttons}</div>
          </div>`;
        })
        .join("");

      wrap.querySelectorAll<HTMLButtonElement>(".tx-mesoday").forEach(btn => {
        btn.onclick = () => goDay(+btn.dataset.day!);
      });

      // disable prev/next at the first/last mesocycle
      const isFirst = phaseIndex === 0 && mesocycleIndex === 0;
      const isLast =
        phaseIndex === phaseList.length - 1 &&
        mesocycleIndex === phaseList[phaseIndex].mesocycles.length - 1;
      ($("tx-prev") as HTMLButtonElement)!.disabled = isFirst;
      ($("tx-next") as HTMLButtonElement)!.disabled = isLast;
    }

    $("tx-prev")!.onclick = () => stepMesocycle(-1);
    $("tx-next")!.onclick = () => stepMesocycle(1);
    const pos = $("tx-pos")!;
    pos.onclick = () => goDay(dayIndex);
    pos.onkeydown = e => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        goDay(dayIndex);
      }
    };

    applyRoute();
    if (!location.search) {
      const td = findToday();
      if (td) {
        phaseIndex = td.phaseIndex;
        mesocycleIndex = td.mesocycleIndex;
        dayIndex = td.dayIndex;
      }
    }

    render();
    fetch("/running/calendar/activities.json", { signal })
      .then(r => (r.ok ? r.json() : []))
      .then((data: Activity[] | Activity) => {
        if (signal.aborted) return;
        acts = Array.isArray(data) ? data : [];
        render();
      })
      .catch(() => {
        if (!signal.aborted) render();
      });
  }

  document.addEventListener("astro:after-swap", init);
  init();
</script>
