---
import { getLocalePath, translations, type Locale } from "@/i18n";

interface Props {
  lang: Locale;
}
const { lang } = Astro.props;
const label = translations[lang].training.calendarLink;
const href = getLocalePath(lang, "running/calendar/");
---

<a
  href={href}
  class="tx-cal-link relative inline-flex shrink-0 items-center gap-1 px-3 py-1.5 text-sm font-bold text-foreground transition-colors hover:text-[var(--yellow)]"
>
  <!-- Sketchy outline as a real element (not ::after): SVG displacement filters
       don't reliably apply to pseudo-elements, so we use a child <span> to get a
       visible hand-drawn wobble while keeping the text crisp. -->
  <span class="tx-cal-link__outline" aria-hidden="true"></span>
  <span class="relative">{label}</span>
</a>

<style>
  .tx-cal-link {
    isolation: isolate;
  }
  .tx-cal-link__outline {
    position: absolute;
    inset: -2px -3px;
    /* Opaque page-color fill is invisible against the page background but gives
       the SVG displacement filter an area to deform — without it the border
       renders straight (feDisplacementMap only shows on filled shapes). */
    background: var(--background);
    border: 2px solid var(--yellow);
    border-radius: 0.5rem;
    filter: url(#sketchy-box);
    pointer-events: none;
    z-index: -1;
  }
</style>
